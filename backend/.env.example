# ── DevRadar Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your keys.
# The app works without any keys (runs on local Map fallback + static data).

# ── HydraDB (persistent memory graph) ─────────────────────────────────────────
# Get your key at https://hydradb.io
# Without this, user data is stored in-process (lost on restart).
HYDRADB_API_KEY=your_hydradb_api_key_here
HYDRADB_PROJECT_ID=your_hydradb_project_id_here
HYDRADB_BASE_URL=https://api.hydradb.io

# ── Groq AI (FREE — recommended for hackathon) ─────────────────────────────────
# Get a free key at https://console.groq.com
# Powers: wiki ingest, career chat, roadmap generation
# Model: llama-3.3-70b-versatile (fast, free tier)
GROQ_API_KEY=your_groq_api_key_here

# ── Anthropic Claude (paid fallback) ──────────────────────────────────────────
# Only used if GROQ_API_KEY is NOT set.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
